{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A cosmetic product in the inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "arrivalDate": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "name", "quantity", "price"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A record of a sale",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "totalPrice": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["id", "productId", "quantity", "totalPrice", "date"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "customerInfo": { "type": "object" },
        "status": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["id", "orderId", "items", "total", "customerInfo", "status", "date"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Collection of sales"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    }
  }
}
